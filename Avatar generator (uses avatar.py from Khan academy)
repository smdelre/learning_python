import avatar
import random

bow_number = random.randint(1,3)



nose_shape_number = random.randint(1,2)
#assigning a nose shape to a random number
if nose_shape_number == 1:
    nose_shape = "triangle"
else:
    nose_shape = "button"

mouth_shape_number = random.randint(1,4)
if mouth_shape_number == 1:
    mouth_shape = "teeth"
elif mouth_shape_number == 2:
    mouth_shape = "neutral"
else:
    mouth_shape = "smile"



if bow_number == 1:
    avatar.draw_bow()

avatar.draw_eyes("medium")
avatar.draw_nose(nose_shape)
avatar.draw_mouth(mouth_shape)

if bow_number == 2:
    avatar.draw_bow()
